{
  "manifest_version": 3,
  "name": "PriorityPing CMU Canvas",
  "version": "2.0.0",
  "description": "Smart notification triage for CMU Canvas with dual-bucket explainability.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "icons": {
    "128": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["*://canvas.cmu.edu/*"],
      "js": ["classifier.js", "ui.js", "content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["model/weights.json"],
      "matches": ["*://canvas.cmu.edu/*"]
    }
  ]
}
