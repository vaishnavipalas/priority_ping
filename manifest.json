{
  "manifest_version": 3,
  "name": "PriorityPing for CMU Canvas",
  "version": "1.0.0",
  "description": "Smart notification triage for CMU Canvas built with Human-AI principles.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["*://canvas.cmu.edu/*"],
      "js": ["classifier.js", "demo_data.js", "ui.js", "content.js"],
      "css": ["styles.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["weights.json"],
      "matches": ["*://canvas.cmu.edu/*"]
    }
  ],
  "icons": {
    "128": "icons/icon.svg"
  }
}
