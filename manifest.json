{
  "manifest_version": 3,
  "name": "PriorityPing",
  "version": "1.0.0",
  "description": "Smart academic notification triage for Canvas LMS at CMU.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://canvas.cmu.edu/*",
    "https://*.instructure.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "icons": {
    "128": "icons/icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["model/weights.json"],
      "matches": [
        "https://canvas.cmu.edu/*",
        "https://*.instructure.com/*"
      ]
    }
  ]
}
